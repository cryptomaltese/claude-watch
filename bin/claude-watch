#!/usr/bin/env bash
set -euo pipefail

VERSION="0.1.0"
CONFIG_DIR="${CLAUDE_WATCH_CONFIG_DIR:-$HOME/.claude-watch}"
CONFIG_FILE="$CONFIG_DIR/config.json"
LOG_FILE="${CLAUDE_WATCH_LOG:-$CONFIG_DIR/claude-watch.log}"
SESSION_PREFIX="claude-"

# --- Logging ---

log() {
    local level="$1"; shift
    local ts
    ts=$(date '+%Y-%m-%d %H:%M:%S')
    echo "$ts [$level] $*" >> "$LOG_FILE"
}

log_info()  { log "INFO"  "$@"; }
log_warn()  { log "WARN"  "$@"; }
log_error() { log "ERROR" "$@"; }

# --- Config ---

ensure_config_dir() {
    mkdir -p "$CONFIG_DIR"
}

load_config() {
    if [ -f "$CONFIG_FILE" ]; then
        CONFIG_SOURCE="file"
    else
        CONFIG_SOURCE="convention"
    fi
}

# Get a value from config.json. Falls back to default if no config or key missing.
config_get() {
    local key="$1"
    local default="${2:-}"
    if [ "$CONFIG_SOURCE" = "file" ] && command -v jq &>/dev/null; then
        local val
        val=$(jq -r ".$key // empty" "$CONFIG_FILE" 2>/dev/null)
        if [ -n "$val" ]; then
            echo "$val"
            return
        fi
    fi
    echo "$default"
}

# Get the sessions directory (where project folders with CLAUDE.md live)
get_sessions_dir() {
    config_get "sessionsDir" "${CLAUDE_WATCH_SESSIONS_DIR:-$HOME}"
}

# Get max search depth for project discovery (default: 4)
get_max_depth() {
    config_get "maxDepth" "${CLAUDE_WATCH_MAX_DEPTH:-6}"
}

# Get the tmux session prefix
get_prefix() {
    config_get "prefix" "$SESSION_PREFIX"
}

# Get extra claude flags for a session
get_session_flags() {
    local name="$1"
    if [ "$CONFIG_SOURCE" = "file" ] && command -v jq &>/dev/null; then
        jq -r ".sessions[\"$name\"].flags // empty" "$CONFIG_FILE" 2>/dev/null
    fi
}

# Check if remote control is enabled (default: true)
get_remote_control() {
    config_get "remoteControl" "true"
}

# Check if resume is enabled (default: true)
get_resume() {
    config_get "resume" "true"
}

# --- Session discovery ---

# Convert a directory path to the claude project slug
path_to_slug() {
    local dir="$1"
    # Claude Code slugifies paths: / and . become -, leading / dropped
    local resolved
    resolved=$(cd "$dir" && pwd)
    echo "$resolved" | sed 's|^/||; s|[/.]|-|g; s|^|-|'
}

# Find the most recent session ID for a project
find_latest_session() {
    local dir="$1"
    local slug
    slug=$(path_to_slug "$dir")
    local session_dir="$HOME/.claude/projects/$slug"

    if [ -d "$session_dir" ]; then
        local latest
        latest=$(ls -t "$session_dir"/*.jsonl 2>/dev/null | head -1)
        if [ -n "$latest" ]; then
            basename "$latest" .jsonl
            return
        fi
    fi
    return 1
}

# Reverse a slug back to a filesystem path
slug_to_path() {
    # Slug format: -home-user--openclaw-workspace (leading dash, / became -, . became -)
    # We can't perfectly reverse . vs - ambiguity, so we check if the path exists
    local slug="$1"
    # Remove leading dash, replace - with /
    local candidate
    candidate=$(echo "$slug" | sed 's|^-|/|; s|-|/|g')
    # Try the direct path first
    if [ -d "$candidate" ]; then
        echo "$candidate"
        return
    fi
    # Try common dot-replacements (.openclaw, .claude, .config, .local, etc.)
    # Replace known patterns where / should be .
    for dotdir in openclaw claude config local ssh; do
        local try
        try=$(echo "$candidate" | sed "s|/${dotdir}|/.${dotdir}|g")
        if [ -d "$try" ]; then
            echo "$try"
            return
        fi
    done
    return 1
}

# List all discovered projects from session history
discover_projects() {
    local sessions_dir
    sessions_dir=$(get_sessions_dir)
    for project_dir in "$HOME/.claude/projects"/*/; do
        [ ! -d "$project_dir" ] && continue
        # Must have at least one .jsonl session file
        ls "$project_dir"/*.jsonl &>/dev/null || continue
        local slug
        slug=$(basename "$project_dir")
        local dir
        if dir=$(slug_to_path "$slug"); then
            # If sessionsDir is set and not $HOME, filter to that subtree
            if [ "$sessions_dir" != "$HOME" ]; then
                case "$dir" in
                    "$sessions_dir"*) echo "$dir" ;;
                esac
            else
                echo "$dir"
            fi
        fi
    done
}

# --- Session management ---

session_name() {
    local name="$1"
    echo "$(get_prefix)$name"
}

is_session_alive() {
    local session="$1"
    tmux has-session -t "$session" 2>/dev/null
}

start_session() {
    local dir="$1"
    local name
    name=$(basename "$dir")
    local session
    session=$(session_name "$name")

    if is_session_alive "$session"; then
        echo "Session $session is already running"
        return 0
    fi

    # Build claude command
    local cmd="claude --dangerously-skip-permissions --permission-mode bypassPermissions"

    # Add memory dir access
    local slug
    slug=$(path_to_slug "$dir")
    local memory_dir="$HOME/.claude/projects/$slug/memory"
    if [ -d "$memory_dir" ]; then
        cmd="$cmd --add-dir $memory_dir"
    fi

    # Resume from latest session if enabled
    if [ "$(get_resume)" = "true" ]; then
        local sid
        if sid=$(find_latest_session "$dir"); then
            cmd="$cmd --resume $sid --fork-session"
            log_info "$session resuming session $sid"
        fi
    fi

    # Add per-session flags from config
    local extra_flags
    extra_flags=$(get_session_flags "$name")
    if [ -n "$extra_flags" ]; then
        cmd="$cmd $extra_flags"
    fi

    # Launch in tmux
    tmux new-session -d -s "$session" -c "$dir" "$cmd"
    log_info "$session started in $dir"

    # Activate remote control if enabled
    if [ "$(get_remote_control)" = "true" ]; then
        activate_remote_control "$session"
    fi

    echo "Started $session"
}

stop_session() {
    local name="$1"
    local session
    session=$(session_name "$name")

    if ! is_session_alive "$session"; then
        echo "Session $session is not running"
        return 0
    fi

    tmux kill-session -t "$session"
    log_info "$session stopped"
    echo "Stopped $session"
}

activate_remote_control() {
    local session="$1"
    local max_attempts=3
    local wait_secs=10

    for attempt in $(seq 1 $max_attempts); do
        sleep "$wait_secs"
        tmux send-keys -t "$session" '/remote-control' Enter
        log_info "$session remote-control attempt $attempt"
        sleep 3

        if tmux capture-pane -t "$session" -p 2>/dev/null | grep -qi 'remote.control'; then
            log_info "$session remote-control confirmed on attempt $attempt"
            return 0
        fi
    done

    log_warn "$session remote-control not confirmed after $max_attempts attempts"
    return 1
}

# --- Commands ---

cmd_scan() {
    local sessions_dir
    sessions_dir=$(get_sessions_dir)
    local started=0
    local alive=0

    while IFS= read -r dir; do
        local name
        name=$(basename "$dir")
        local session
        session=$(session_name "$name")

        if is_session_alive "$session"; then
            ((alive++))
        else
            start_session "$dir"
            ((started++))
        fi
    done < <(discover_projects)

    if [ "$started" -gt 0 ]; then
        log_info "scan complete: $started started, $alive already running"
    fi
}

cmd_status() {
    local sessions_dir
    sessions_dir=$(get_sessions_dir)
    local prefix
    prefix=$(get_prefix)

    printf "%-20s %-10s %-40s %s\n" "SESSION" "STATUS" "DIRECTORY" "SESSION ID"
    printf "%-20s %-10s %-40s %s\n" "-------" "------" "---------" "----------"

    while IFS= read -r dir; do
        local name
        name=$(basename "$dir")
        local session
        session=$(session_name "$name")
        local status="DEAD"
        local sid="-"

        if is_session_alive "$session"; then
            status="ALIVE"
        fi

        if s=$(find_latest_session "$dir" 2>/dev/null); then
            sid="${s:0:8}..."
        fi

        printf "%-20s %-10s %-40s %s\n" "$session" "$status" "$dir" "$sid"
    done < <(discover_projects)
}

cmd_start() {
    local target="${1:-}"
    local sessions_dir
    sessions_dir=$(get_sessions_dir)

    if [ -z "$target" ]; then
        # Start all
        while IFS= read -r dir; do
            start_session "$dir"
        done < <(discover_projects)
    else
        local dir="$sessions_dir/$target"
        if [ ! -f "$dir/CLAUDE.md" ]; then
            echo "Error: No CLAUDE.md found in $dir"
            exit 1
        fi
        start_session "$dir"
    fi
}

cmd_stop() {
    local target="${1:-}"

    if [ -z "$target" ]; then
        # Stop all
        while IFS= read -r dir; do
            local name
            name=$(basename "$dir")
            stop_session "$name"
        done < <(discover_projects)
    else
        stop_session "$target"
    fi
}

cmd_restart() {
    local target="${1:-}"

    if [ -z "$target" ]; then
        cmd_stop
        sleep 2
        cmd_start
    else
        cmd_stop "$target"
        sleep 2
        cmd_start "$target"
    fi
}

cmd_add() {
    local dir="${1:?Usage: claude-watch add <directory>}"
    dir=$(cd "$dir" && pwd)

    if [ ! -d "$dir" ]; then
        echo "Error: $dir is not a directory"
        exit 1
    fi

    if [ ! -f "$dir/CLAUDE.md" ]; then
        echo "No CLAUDE.md found in $dir. Create one? [y/N]"
        read -r answer
        if [[ "$answer" =~ ^[Yy] ]]; then
            touch "$dir/CLAUDE.md"
            echo "Created $dir/CLAUDE.md"
        else
            echo "Aborted. A CLAUDE.md is required for claude-watch to manage this directory."
            exit 1
        fi
    fi

    echo "Directory $dir is ready for claude-watch."
    echo "It will be picked up on the next scan if it's under the sessions directory."
    echo "Current sessions directory: $(get_sessions_dir)"
}

cmd_list() {
    echo "Sessions directory: $(get_sessions_dir)"
    echo "Config: ${CONFIG_SOURCE:-none}"
    echo ""
    discover_projects | while IFS= read -r dir; do
        echo "  $(basename "$dir")  →  $dir"
    done
}

cmd_install() {
    ensure_config_dir

    echo "Installing claude-watch..."

    # Detect init system
    if command -v systemctl &>/dev/null && systemctl --user status &>/dev/null 2>&1; then
        install_systemd
    else
        install_cron
    fi

    echo ""
    echo "Installation complete."
    echo "Sessions directory: $(get_sessions_dir)"
    echo "Config: $CONFIG_FILE"
    echo "Log: $LOG_FILE"
}

install_cron() {
    local script_path
    script_path=$(realpath "$0")
    local sessions_dir
    sessions_dir=$(get_sessions_dir)
    local cron_line="*/5 * * * * cd $sessions_dir && $script_path scan >> $LOG_FILE 2>&1"

    # Check if already installed
    if crontab -l 2>/dev/null | grep -q "claude-watch"; then
        echo "Cron job already exists. Updating..."
        crontab -l 2>/dev/null | grep -v "claude-watch" | { cat; echo "$cron_line"; } | crontab -
    else
        (crontab -l 2>/dev/null; echo "$cron_line") | crontab -
    fi
    echo "Installed cron job (every 5 minutes)"
}

install_systemd() {
    local script_path
    script_path=$(realpath "$0")
    local sessions_dir
    sessions_dir=$(get_sessions_dir)
    local unit_dir="$HOME/.config/systemd/user"
    mkdir -p "$unit_dir"

    cat > "$unit_dir/claude-watch.service" <<EOF
[Unit]
Description=Claude Watch - session watchdog scan
After=network.target

[Service]
Type=oneshot
ExecStart=$script_path scan
WorkingDirectory=$sessions_dir
Environment=PATH=$PATH
EOF

    cat > "$unit_dir/claude-watch.timer" <<EOF
[Unit]
Description=Claude Watch - run every 5 minutes

[Timer]
OnBootSec=1min
OnUnitActiveSec=5min
Persistent=true

[Install]
WantedBy=timers.target
EOF

    systemctl --user daemon-reload
    systemctl --user enable --now claude-watch.timer
    echo "Installed systemd timer (every 5 minutes)"
}

cmd_uninstall() {
    echo "Uninstalling claude-watch..."

    # Remove cron
    if crontab -l 2>/dev/null | grep -q "claude-watch"; then
        crontab -l 2>/dev/null | grep -v "claude-watch" | crontab -
        echo "Removed cron job"
    fi

    # Remove systemd
    if [ -f "$HOME/.config/systemd/user/claude-watch.timer" ]; then
        systemctl --user disable --now claude-watch.timer 2>/dev/null || true
        rm -f "$HOME/.config/systemd/user/claude-watch.service"
        rm -f "$HOME/.config/systemd/user/claude-watch.timer"
        systemctl --user daemon-reload
        echo "Removed systemd timer"
    fi

    echo "Uninstalled. Config and logs preserved at $CONFIG_DIR"
}

cmd_logs() {
    local lines="${1:-50}"
    if [ -f "$LOG_FILE" ]; then
        tail -n "$lines" "$LOG_FILE"
    else
        echo "No log file found at $LOG_FILE"
    fi
}

cmd_version() {
    echo "claude-watch v$VERSION"
}

cmd_help() {
    cat <<EOF
claude-watch v$VERSION — persistent auto-resuscitating Claude Code sessions

Usage: claude-watch <command> [args]

Commands:
  scan              Run one watchdog cycle (start dead sessions)
  status            Show status of all watched sessions
  start [name]      Start a session (or all if no name given)
  stop [name]       Stop a session (or all)
  restart [name]    Restart a session (or all)
  list              List discovered project directories
  add <dir>         Prepare a directory for watching
  logs [n]          Show last n log lines (default: 50)
  install           Set up cron or systemd timer
  uninstall         Remove cron/systemd timer
  version           Show version
  help              Show this help

Environment:
  CLAUDE_WATCH_SESSIONS_DIR   Override sessions directory
  CLAUDE_WATCH_CONFIG_DIR     Override config directory (default: ~/.claude-watch)
  CLAUDE_WATCH_LOG            Override log file path

Config: $CONFIG_DIR/config.json (optional — convention-based by default)
EOF
}

# --- Main ---

main() {
    ensure_config_dir
    load_config

    local cmd="${1:-help}"
    shift 2>/dev/null || true

    case "$cmd" in
        scan)       cmd_scan "$@" ;;
        status)     cmd_status "$@" ;;
        start)      cmd_start "$@" ;;
        stop)       cmd_stop "$@" ;;
        restart)    cmd_restart "$@" ;;
        list)       cmd_list "$@" ;;
        add)        cmd_add "$@" ;;
        logs)       cmd_logs "$@" ;;
        install)    cmd_install "$@" ;;
        uninstall)  cmd_uninstall "$@" ;;
        version|-v|--version) cmd_version ;;
        help|-h|--help)       cmd_help ;;
        *)
            echo "Unknown command: $cmd"
            echo "Run 'claude-watch help' for usage"
            exit 1
            ;;
    esac
}

main "$@"
