#!/usr/bin/env bash
set -euo pipefail

SENTINEL=$(mktemp -t claude-watch-attach.XXXXXX)
export CLAUDE_WATCH_SENTINEL="$SENTINEL"

SCRIPT_DIR="$(dirname "$(realpath "$0")")"
DIST="$SCRIPT_DIR/../dist/cli.js"

node "$DIST" "$@"
RC=$?

if [ -s "$SENTINEL" ]; then
    TARGET=$(cat "$SENTINEL")
    rm -f "$SENTINEL"
    exec tmux attach -t "$TARGET"
fi

rm -f "$SENTINEL"
exit $RC
