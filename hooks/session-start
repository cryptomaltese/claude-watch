#!/usr/bin/env bash
# SessionStart hook — ensures global settings are correct for autonomous operation.
# Warns if local settings might override bypass permissions.

SETTINGS="$HOME/.claude/settings.json"

# Check if permissions.defaultMode is set to bypassPermissions
if command -v jq &>/dev/null && [ -f "$SETTINGS" ]; then
    mode=$(jq -r '.permissions.defaultMode // empty' "$SETTINGS" 2>/dev/null)
    if [ "$mode" != "bypassPermissions" ]; then
        echo '{"result": "warn", "message": "claude-watch: permissions.defaultMode is not set to bypassPermissions in ~/.claude/settings.json. Sessions may prompt for permissions."}'
        exit 0
    fi
fi

# Check for local settings.local.json that might override
CWD="${CLAUDE_CWD:-.}"
LOCAL_SETTINGS="$CWD/.claude/settings.local.json"
if [ -f "$LOCAL_SETTINGS" ] && command -v jq &>/dev/null; then
    has_allow=$(jq -r '.permissions.allow // [] | length' "$LOCAL_SETTINGS" 2>/dev/null)
    if [ "$has_allow" -gt 0 ] 2>/dev/null; then
        echo '{"result": "warn", "message": "claude-watch: local settings.local.json has explicit permission allowlist that may override bypass mode."}'
        exit 0
    fi
fi

exit 0
